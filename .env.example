# Database
POSTGRES_DB=mailtracker
POSTGRES_USER=mailtracker_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Django
DEBUG=False
SECRET_KEY=change_me_to_random_50_char_string
ALLOWED_HOSTS=localhost,127.0.0.1,your-tunnel.trycloudflare.com,your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-vercel-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-tunnel.trycloudflare.com,https://your-domain.com
USE_X_FORWARDED_HOST=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
DATABASE_URL=postgres://mailtracker_user:change_me@postgres:5432/mailtracker
BOOTSTRAP_ON_START=True
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@office.gov
DJANGO_SUPERUSER_PASSWORD=change_me_now
DJANGO_SUPERUSER_FULL_NAME=System Administrator
DJANGO_SUPERUSER_ACTUAL_ROLE=Accountant General
INITIAL_SECTIONS_FILE=/app/sample_data/sections_sample.json
INITIAL_SECTIONS_UPDATE_EXISTING=True
INITIAL_USERS_FILE=
INITIAL_USERS_UPDATE_EXISTING=False

# PDF Storage
PDF_STORAGE_PATH=/srv/mailtracker/pdfs
MAX_PDF_SIZE_MB=10

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=1440
REFRESH_TOKEN_LIFETIME_DAYS=7
